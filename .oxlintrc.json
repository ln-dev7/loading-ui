{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "oxc",
    "import",
    "jsdoc",
    "node",
    "promise"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "env": {
    "builtin": true
  },
  "settings": {
    "react": {
      "version": "19.2.5"
    },
    "tailwindcss": {
      "callees": ["clsx", "cva", "cn"]
    }
  },
  "rules": {
    "no-unsafe-type-assertion": "off"
  },
  "ignorePatterns": ["node_modules/", "dist/"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  }
}
